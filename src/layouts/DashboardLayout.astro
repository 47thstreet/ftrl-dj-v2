---
interface Props {
  title: string;
  activeTab?: string;
}

const { title, activeTab } = Astro.props;
const user = (Astro.locals as any).user;

const tabs = [
  { href: '/dashboard', label: 'Overview', id: 'overview' },
  { href: '/dashboard/profile', label: 'Profile', id: 'profile' },
  { href: '/dashboard/events', label: 'Events', id: 'events' },
  { href: '/dashboard/media', label: 'Media', id: 'media' },
  { href: '/dashboard/availability', label: 'Availability', id: 'availability' },
];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — FTRL Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #0a0a0f;
      color: white;
      min-height: 100vh;
    }
    a { color: inherit; text-decoration: none; }

    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      background: rgba(10,10,15,0.95);
      backdrop-filter: blur(12px);
      position: sticky; top: 0; z-index: 50;
    }
    .topbar-left { display: flex; align-items: center; gap: 1.5rem; }
    .topbar-logo {
      font-size: 1.25rem; font-weight: 900;
      letter-spacing: 0.1em;
      background: linear-gradient(135deg, #8b5cf6, #ec4899);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .topbar-user {
      display: flex; align-items: center; gap: 0.75rem;
    }
    .topbar-name {
      font-size: 0.8125rem; font-weight: 600;
      color: rgba(255,255,255,0.5);
    }
    .topbar-logout {
      font-size: 0.6875rem; font-weight: 700;
      color: rgba(255,255,255,0.2);
      padding: 0.375rem 0.75rem;
      border-radius: 0.375rem;
      border: 1px solid rgba(255,255,255,0.08);
      background: none;
      cursor: pointer;
      transition: all 0.2s;
    }
    .topbar-logout:hover {
      color: rgba(255,255,255,0.5);
      border-color: rgba(255,255,255,0.15);
    }

    .tabs {
      display: flex; gap: 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 0 1.5rem;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .tab {
      padding: 0.75rem 1rem;
      font-size: 0.8125rem; font-weight: 600;
      color: rgba(255,255,255,0.3);
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
      white-space: nowrap;
    }
    .tab:hover { color: rgba(255,255,255,0.6); }
    .tab.active {
      color: white;
      border-bottom-color: #8b5cf6;
    }

    .content {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    .page-title {
      font-size: 1.5rem; font-weight: 800;
      margin-bottom: 1.5rem;
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-left">
      <a href="/" class="topbar-logo">FTRL</a>
    </div>
    <div class="topbar-user">
      <span class="topbar-name">{user?.name}</span>
      <form action="/api/auth/logout" method="POST" style="display:inline;">
        <button type="submit" class="topbar-logout">Sign out</button>
      </form>
    </div>
  </div>

  <nav class="tabs">
    {tabs.map(tab => (
      <a href={tab.href} class={`tab ${activeTab === tab.id ? 'active' : ''}`}>{tab.label}</a>
    ))}
  </nav>

  <main class="content">
    <slot />
  </main>
</body>
</html>
