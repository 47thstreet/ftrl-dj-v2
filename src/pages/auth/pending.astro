---
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Account Pending — FTRL</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #050507;
      color: white;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      max-width: 420px;
      padding: 3rem 2rem;
      text-align: center;
    }
    .icon {
      font-size: 3rem;
      margin-bottom: 1.5rem;
    }
    h1 {
      font-size: 1.5rem; font-weight: 800;
      margin-bottom: 0.75rem;
    }
    p {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.4);
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }
    a {
      display: inline-block;
      padding: 0.625rem 1.5rem;
      border-radius: 0.5rem;
      font-size: 0.8125rem; font-weight: 700;
      color: white;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      text-decoration: none;
      transition: all 0.2s;
    }
    a:hover {
      background: rgba(255,255,255,0.1);
      border-color: rgba(255,255,255,0.15);
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">&#9203;</div>
    <h1>Account Pending</h1>
    <p>Your account has been created but needs approval from an admin before you can access the dashboard. We'll notify you when your account is activated.</p>
    <a href="/">Back to FTRL</a>
  </div>
</body>
</html>
