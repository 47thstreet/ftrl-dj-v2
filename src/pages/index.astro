---
import { getDjBySlug } from '../data/djs';

// Extract subdomain from host header
const host = Astro.request.headers.get('host') || '';
const parts = host.split('.');

let subdomain = '';
// Only treat as subdomain for ftrl.ink (not netlify.app or localhost)
const isCustomDomain = host.endsWith('.ftrl.ink');
if (isCustomDomain && parts.length >= 3 && parts[0] !== 'www') {
  subdomain = parts[0];
}

// If we have a subdomain, resolve the DJ
let dj: any = null;
if (subdomain) {
  if (process.env.DATABASE_URL) {
    try {
      const { prisma } = await import('../lib/prisma');
      const site = await prisma.promoterSite.findUnique({
        where: { slug: subdomain },
        include: { promoter: { include: { user: true } } },
      });
      if (site) {
        const socials = (typeof site.socialLinks === 'object' && site.socialLinks !== null) ? site.socialLinks as Record<string, string> : {};
        dj = {
          slug: site.slug,
          name: site.promoter.displayName,
          tagline: site.tagline,
          bio: site.bio,
          primaryColor: site.primaryColor,
          accentColor: site.accentColor,
          heroImage: site.heroImage,
          logoImage: site.logoImage,
          socialLinks: socials,
          instagram: socials.instagram ? socials.instagram.replace('https://instagram.com/', '') : '',
        };
      }
    } catch {}
  }
  if (!dj) {
    const seed = getDjBySlug(subdomain);
    if (seed) dj = seed;
  }
}

if (dj) {
  return Astro.redirect(`/dj/${dj.slug}`);
} else if (subdomain) {
  return Astro.redirect('/404');
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FTRL — Artist Link Pages</title>
  <meta name="description" content="FTRL — Premium link-in-bio pages for DJs and artists. Your sound, your brand, one link." />
  <meta property="og:title" content="FTRL" />
  <meta property="og:description" content="Premium link-in-bio pages for DJs and artists." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #050507;
      color: white;
      min-height: 100vh;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }

    /* ── Background with lava lamp ── */
    .bg {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      overflow: hidden;
    }
    .lava-blob {
      position: absolute; border-radius: 50%;
      filter: blur(80px);
    }
    .lava-blob-1 {
      width: 50vw; height: 50vw; max-width: 500px; max-height: 500px;
      background: rgba(139,92,246,0.15);
      top: -10%; left: 30%;
      animation: lavaMove1 20s ease-in-out infinite;
    }
    .lava-blob-2 {
      width: 40vw; height: 40vw; max-width: 400px; max-height: 400px;
      background: rgba(236,72,153,0.08);
      top: 20%; right: 10%;
      animation: lavaMove2 25s ease-in-out infinite;
    }
    .lava-blob-3 {
      width: 35vw; height: 35vw; max-width: 350px; max-height: 350px;
      background: rgba(6,182,212,0.06);
      bottom: 10%; left: 15%;
      animation: lavaMove3 22s ease-in-out infinite;
    }
    @keyframes lavaMove1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      25% { transform: translate(10vw, 5vh) scale(1.1); }
      50% { transform: translate(-5vw, 10vh) scale(0.9); }
      75% { transform: translate(5vw, -5vh) scale(1.05); }
    }
    @keyframes lavaMove2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      25% { transform: translate(-8vw, 8vh) scale(0.95); }
      50% { transform: translate(5vw, -3vh) scale(1.1); }
      75% { transform: translate(-3vw, 5vh) scale(1); }
    }
    @keyframes lavaMove3 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(-10vw, -5vh) scale(1.15); }
      66% { transform: translate(8vw, 8vh) scale(0.9); }
    }
    .noise {
      position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    .page {
      position: relative; z-index: 1;
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 3rem 1.5rem;
    }

    /* ── Hero ── */
    .hero {
      text-align: center;
      max-width: 600px;
      animation: fadeUp 0.8s ease-out;
    }

    .logo {
      font-size: 5rem; font-weight: 900;
      letter-spacing: 0.12em;
      line-height: 1;
      background: linear-gradient(to bottom, white, rgba(255,255,255,0.5));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1.5rem;
    }

    .tagline {
      font-size: 1.125rem; font-weight: 600;
      color: rgba(255,255,255,0.4);
      line-height: 1.6;
      max-width: 420px; margin: 0 auto;
    }
    .tagline strong {
      color: rgba(255,255,255,0.7);
      font-weight: 700;
    }

    /* ── DJ Login ── */
    .dj-login {
      display: inline-flex; align-items: center; gap: 0.5rem;
      margin-top: 2.5rem;
      padding: 0.625rem 1.25rem;
      border-radius: 999px;
      font-size: 0.75rem; font-weight: 700;
      letter-spacing: 0.06em;
      color: rgba(255,255,255,0.25);
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      transition: all 0.25s;
      animation: fadeUp 0.8s ease-out 0.2s both;
    }
    .dj-login:hover {
      color: rgba(255,255,255,0.6);
      border-color: rgba(139,92,246,0.3);
      background: rgba(139,92,246,0.06);
      box-shadow: 0 4px 20px rgba(139,92,246,0.1);
      transform: translateY(-1px);
    }
    .dj-login svg { opacity: 0.6; }

    /* ── Footer ── */
    .footer {
      margin-top: 4rem; text-align: center;
      animation: fadeUp 0.8s ease-out 0.3s both;
    }
    .footer-links {
      display: flex; align-items: center; justify-content: center;
      gap: 1.5rem; margin-bottom: 1rem;
    }
    .footer-link {
      font-size: 0.625rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(255,255,255,0.12);
      transition: color 0.2s;
    }
    .footer-link:hover { color: rgba(255,255,255,0.3); }

    .footer-sub {
      font-size: 0.5rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(255,255,255,0.06);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 480px) {
      .logo { font-size: 3.5rem; }
      .tagline { font-size: 1rem; }
    }
  </style>
</head>
<body>
  <div class="bg">
    <div class="lava-blob lava-blob-1"></div>
    <div class="lava-blob lava-blob-2"></div>
    <div class="lava-blob lava-blob-3"></div>
  </div>
  <div class="noise"></div>

  <div class="page">

    <!-- ── Hero ── -->
    <div class="hero">
      <h1 class="logo">FTRL</h1>
      <p class="tagline">
        <strong>Your sound. Your brand.</strong><br />
        One link.
      </p>
    </div>

    <!-- ── DJ Login ── -->
    <a href="/auth/login" class="dj-login">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      DJ Login
    </a>

    <!-- ── Footer ── -->
    <div class="footer">
      <div class="footer-links">
        <a href="https://future-productions.vercel.app" target="_blank" rel="noopener" class="footer-link">Future Productions</a>
        <a href="mailto:booking@ftrl.ink" class="footer-link">Bookings</a>
      </div>
      <p class="footer-sub">Powered by Kartis</p>
    </div>

  </div>
</body>
</html>
